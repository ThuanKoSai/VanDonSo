# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/supply-chain-traceability

# --- Server ---
PORT=8080
NODE_ENV=development
# Domain frontend được phép gọi API (CORS). Để * khi dev local;
# khi deploy thật, đổi thành domain thật, VD: https://vandonso.vercel.app
FRONTEND_ORIGIN=*

# --- Blockchain (chỉ dùng để ĐỌC on-chain, backend không giữ private key ghi) ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# --- Admin ---
# Địa chỉ ví Admin duy nhất được phép gọi các route ghi (VD: POST /api/admin/users).
# Backend xác thực bằng CHỮ KÝ VÍ (xem middleware/adminAuth.js), không dùng JWT/mật khẩu.
ADMIN_WALLET_ADDRESS=0xYourAdminWalletAddress
